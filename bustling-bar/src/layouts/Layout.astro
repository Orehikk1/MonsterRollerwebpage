  <aside
    id="cookie-consent"
    class="fixed left-4 right-4 bottom-4 sm:left-6 sm:right-auto sm:max-w-sm z-[70] hidden translate-y-3 opacity-0 transition-all duration-300"
    aria-live="polite"
  >
    <div class="rounded-2xl border border-orange-300/60 dark:border-orange-500/30 bg-white/95 dark:bg-zinc-900/95 text-zinc-900 dark:text-zinc-100 backdrop-blur-xl shadow-2xl p-4">
      <div class="flex items-start gap-3">
        <div class="shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-300 dark:from-orange-500 dark:to-amber-300 flex items-center justify-center shadow-lg">
          <svg class="w-5 h-5 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 4h10a3 3 0 013 3v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7a3 3 0 013-3z"/>
            <circle cx="9" cy="9" r="1.2" fill="currentColor" stroke="none"/>
            <circle cx="15" cy="8.5" r="1" fill="currentColor" stroke="none"/>
            <circle cx="13" cy="14" r="1.3" fill="currentColor" stroke="none"/>
            <circle cx="8" cy="14.5" r="0.9" fill="currentColor" stroke="none"/>
            <circle cx="16" cy="16.5" r="0.9" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-bold text-zinc-900 dark:text-white text-sm">Cookie Notice</p>
          <p class="mt-1 text-xs leading-5 text-zinc-700 dark:text-zinc-300">We use cookies to improve site performance and your booking experience.</p>
        </div>
      </div>
      <div class="mt-3 flex items-center justify-end gap-2">
        <a href="/privacy" class="px-3 py-2 text-xs font-medium rounded-full border border-zinc-300 dark:border-zinc-600 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition">Info</a>
        <button id="cookie-decline" type="button" class="px-3 py-2 text-xs font-medium rounded-full border border-zinc-300 dark:border-zinc-600 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition">Later</button>
        <button id="cookie-accept" type="button" class="px-4 py-2 text-xs font-bold rounded-full bg-orange-500 hover:bg-orange-400 text-black transition">Accept Cookies</button>
      </div>
    </div>
  </aside>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const footerRoot = document.querySelector('.footer-main-observe');
      if (!footerRoot) return;

      if ('IntersectionObserver' in window) {
        const footerObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          });
        }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

        footerObserver.observe(footerRoot);
      } else {
        footerRoot.classList.add('visible');
      }
    });
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Mobile Menu Toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
      const mobileMenuClose = document.getElementById('mobile-menu-close');
      const mobileMenuLinks = mobileMenuOverlay ? mobileMenuOverlay.querySelectorAll('.mobile-menu-link') : [];
      let closeMenuTimer;

      function openMobileMenu() {
        if (!mobileMenuBtn || !mobileMenuOverlay) return;
        clearTimeout(closeMenuTimer);
        document.body.classList.add('menu-open');
        mobileMenuBtn.classList.add('is-open');
        mobileMenuBtn.setAttribute('aria-expanded', 'true');
        mobileMenuOverlay.classList.remove('is-closing');
        mobileMenuOverlay.classList.add('is-open');
        mobileMenuOverlay.setAttribute('aria-hidden', 'false');
      }

      function closeMobileMenu() {
        if (!mobileMenuBtn || !mobileMenuOverlay) return;
        mobileMenuBtn.classList.remove('is-open');
        mobileMenuBtn.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('menu-open');
        mobileMenuOverlay.classList.remove('is-open');
        mobileMenuOverlay.classList.add('is-closing');
        clearTimeout(closeMenuTimer);
        closeMenuTimer = setTimeout(() => {
          mobileMenuOverlay.classList.remove('is-closing');
          mobileMenuOverlay.setAttribute('aria-hidden', 'true');
        }, 360);
      }

      if (mobileMenuBtn && mobileMenuOverlay) {
        mobileMenuBtn.addEventListener('click', () => {
          const isOpen = mobileMenuOverlay.classList.contains('is-open');
          if (isOpen) {
            closeMobileMenu();
          } else {
            openMobileMenu();
          }
        });

        mobileMenuLinks.forEach((link) => {
          link.addEventListener('click', () => {
            closeMobileMenu();
          });
        });

        if (mobileMenuClose) {
          mobileMenuClose.addEventListener('click', () => {
            closeMobileMenu();
          });
        }

        mobileMenuOverlay.addEventListener('click', (event) => {
          if (event.target === mobileMenuOverlay) {
            closeMobileMenu();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && mobileMenuOverlay.classList.contains('is-open')) {
            closeMobileMenu();
          }
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth >= 1024 && mobileMenuOverlay.classList.contains('is-open')) {
            closeMobileMenu();
          }
        });
      }

      // Theme Toggle
      const toggle = document.getElementById('theme-toggle');
      const siteHeader = document.getElementById('site-header');
      const cookieConsent = document.getElementById('cookie-consent');
      const cookieAccept = document.getElementById('cookie-accept');
      const cookieDecline = document.getElementById('cookie-decline');
      const footerCookieSettings = document.getElementById('footer-cookie-settings');
      let lastScrollY = window.scrollY;
      const COOKIE_KEY = 'mr_cookie_consent_v1';
      
      function setTheme(theme) {
        const root = document.documentElement;
        const rootBase = Array.from(root.classList).filter(cls => cls !== 'light' && cls !== 'dark');
        root.className = [...rootBase, theme].join(' ');

        // Keep body free of theme classes so `dark:*` utilities only follow html.
        if (document.body) {
          document.body.classList.remove('dark', 'light');
        }

        if (toggle) {
          toggle.classList.toggle('is-night', theme === 'dark');
        }

        localStorage.setItem('theme', theme);
      }

      // Keep html/body strictly in sync to avoid mixed-theme rendering.
      const savedTheme = localStorage.getItem('theme') === 'dark' ? 'dark' : 'light';
      setTheme(savedTheme);
      
      if (toggle) {
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.contains('dark');
          setTheme(isDark ? 'light' : 'dark');
        });
      }

      // Hide header on scroll down, show on scroll up
      window.addEventListener('scroll', () => {
        if (!siteHeader) return;

        const currentY = window.scrollY;
        const directionDelta = currentY - lastScrollY;

        if (currentY <= 10) {
          siteHeader.classList.remove('-translate-y-full');
          lastScrollY = currentY;
          return;
        }

        if (directionDelta > 8) {
          siteHeader.classList.add('-translate-y-full');
        } else if (directionDelta < -8) {
          siteHeader.classList.remove('-translate-y-full');
        }

        lastScrollY = currentY;
      }, { passive: true });

      function hideCookieBanner() {
        if (!cookieConsent) return;
        cookieConsent.classList.add('translate-y-3', 'opacity-0');
        setTimeout(() => cookieConsent.classList.add('hidden'), 300);
      }

      function showCookieBanner() {
        if (!cookieConsent) return;
        cookieConsent.classList.remove('hidden');
        requestAnimationFrame(() => {
          cookieConsent.classList.remove('translate-y-3', 'opacity-0');
        });
      }

      if (cookieConsent && !localStorage.getItem(COOKIE_KEY)) {
        showCookieBanner();
      }

      if (cookieAccept) {
        cookieAccept.addEventListener('click', () => {
          localStorage.setItem(COOKIE_KEY, 'accepted');
          hideCookieBanner();
        });
      }

      if (cookieDecline) {
        cookieDecline.addEventListener('click', () => {
          localStorage.setItem(COOKIE_KEY, 'later');
          hideCookieBanner();
        });
      }

      if (footerCookieSettings) {
        footerCookieSettings.addEventListener('click', () => {
          localStorage.removeItem(COOKIE_KEY);
          showCookieBanner();
        });
      }
    });
  </script>

  <script>
    import { initScrollReveal } from '../scripts/animations.js';
    initScrollReveal();
  </script>

  <style>
    .site-footer {
