---
import '../styles/global.css';
const { title = "Monster Roller Budapest" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Syne:wght@800&display=swap" rel="stylesheet">
  <title>{title} – Ride the Beast!</title>
  <script defer src="/_vercel/insights/script.js"></script>
  <script defer src="/_vercel/speed-insights/script.js"></script>

  <script>
    // Ensure light mode is the default before anything renders
    const html = document.documentElement;
    const saved = localStorage.getItem('theme');
    
    // Always start with light unless explicitly saved as dark
    if (saved !== 'dark') {
      html.classList.add('light');
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      html.classList.remove('light');
    }
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header — кремовый по умолчанию -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[#fffaf0] dark:bg-[#0f1419] backdrop-blur-xl border-b border-orange-300/50 dark:border-[#3d4a7a] shadow-lg">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-2xl sm:text-3xl font-black text-orange-600 dark:text-orange-400 tracking-wider">
        MONSTER ROLLER
      </a>

      <!-- Вот эта строка исправлена — теперь чёрный текст в светлой теме -->
      <div class="hidden lg:flex items-center gap-8 text-base font-bold !text-zinc-950 dark:!text-white hover:text-orange-600 dark:hover:text-orange-400 transition-colors">        
        <a href="/" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Home</a>
        <a href="/#book-your-ride" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Rent</a>
        <a href="/tours" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Tours</a>
        <a href="/about" class="hover:text-orange-500 dark:hover:text-orange-400 transition">About</a>
        <a href="/contact" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Contact</a>
      </div>

      <div class="flex items-center gap-4">
        <a href="https://wa.me/36302584709?text=I%20want%20to%20book%20a%20Monster%20Roller%20now!"
          class="bg-orange-500 hover:bg-orange-400 text-black dark:text-white font-bold px-6 sm:px-7 md:px-8 py-3 sm:py-3 md:py-3.5 rounded-full shadow-lg text-base sm:text-lg md:text-xl transition-all">
          Book Now
        </a>

        <!-- Твоя кнопка солнца/луны (не трогал) -->
        <button id="theme-toggle" class="p-2.5 rounded-full hover:bg-orange-500/20 dark:hover:bg-zinc-800 transition">
          <svg id="sun-icon" class="w-6 h-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <circle cx="12" cy="12" r="5" />
            <line x1="12" y1="1" x2="12" y2="3" />
            <line x1="12" y1="21" x2="12" y2="23" />
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
            <line x1="1" y1="12" x2="3" y2="12" />
            <line x1="21" y1="12" x2="23" y2="12" />
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
          <svg id="moon-icon" class="w-6 h-6 text-yellow-300 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <button id="mobile-menu-btn" class="lg:hidden text-orange-600 dark:text-orange-400 text-3xl">☰</button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 right-0 bg-[#fffaf0] dark:bg-[#0f1419] border-b border-orange-300/50 dark:border-[#3d4a7a] shadow-lg py-4">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col gap-4">
        <a href="/" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Home</a>
        <a href="/#book-your-ride" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Rent</a>
        <a href="/tours" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Tours</a>
        <a href="/about" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">About</a>
        <a href="/contact" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Contact</a>
      </div>
    </div>
  </header>

  <main class="flex-1 pt-20 sm:pt-24">
    <slot />
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Mobile Menu Toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close menu when a link is clicked
      const mobileMenuLinks = mobileMenu.querySelectorAll('a');
      mobileMenuLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });

      // Theme Toggle
      const toggle = document.getElementById('theme-toggle');
      const sun = document.getElementById('sun-icon');
      const moon = document.getElementById('moon-icon');
      
      function setTheme(theme) {
        document.documentElement.classList.remove('dark', 'light');
        document.documentElement.classList.add(theme);
        
        if (theme === 'dark') {
          sun.classList.add('hidden');
          moon.classList.remove('hidden');
        } else {
          moon.classList.add('hidden');
          sun.classList.remove('hidden');
        }
        localStorage.setItem('theme', theme);
      }
      
      // Initialize icons based on current theme
      const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      if (currentTheme === 'dark') {
        sun.classList.add('hidden');
        moon.classList.remove('hidden');
      } else {
        moon.classList.add('hidden');
        sun.classList.remove('hidden');
      }
      
      toggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.contains('dark');
        setTheme(isDark ? 'light' : 'dark');
      });
    });
  </script>
  <script defer src="/_vercel/insights/script.js"></script>
</body>
</html>