---
import '../styles/global.css';
const { title = "Monster Roller Budapest" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Monster Roller Budapest tours and rentals. Explore iconic city routes with guided electric roller rides for beginners, couples, and groups." />
  <title>{title} – Ride the Beast!</title>
  <script is:inline>
    (() => {
      const storedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = storedTheme === 'dark' || (!storedTheme && prefersDark);
      const heroHref = isDark ? '/images/hero-night-dark.webp' : '/images/hero-night.webp';
      const preload = document.createElement('link');
      preload.rel = 'preload';
      preload.as = 'image';
      preload.href = heroHref;
      document.head.appendChild(preload);
    })();
  </script>

  <script is:inline>
    window.addEventListener('load', () => {
      const loadScript = (src) => {
        const script = document.createElement('script');
        script.src = src;
        script.defer = true;
        document.body.appendChild(script);
      };

      const scheduleLoad = (cb) => {
        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(cb, { timeout: 2500 });
        } else {
          setTimeout(cb, 1200);
        }
      };

      scheduleLoad(() => {
        loadScript('/_vercel/insights/script.js');
        loadScript('/_vercel/speed-insights/script.js');
      });
    });
  </script>

  <script>
    // Ensure light mode is the default before anything renders
    const html = document.documentElement;
    const saved = localStorage.getItem('theme');
    const baseClasses = Array.from(html.classList).filter(cls => cls !== 'light' && cls !== 'dark');
    
    // Always start with light unless explicitly saved as dark
    if (saved !== 'dark') {
      html.className = [...baseClasses, 'light'].join(' ');
    } else {
      html.className = [...baseClasses, 'dark'].join(' ');
    }
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header — кремовый по умолчанию -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-[#fffaf0] dark:bg-[#0f1419] backdrop-blur-xl border-b border-orange-300/50 dark:border-[#3d4a7a] shadow-lg transition-transform duration-300 will-change-transform">
    <nav class="max-w-7xl mx-auto px-3 sm:px-6 py-3 sm:py-4 flex items-center justify-between gap-2 sm:gap-4">
      <a href="/" class="min-w-0 text-xl sm:text-3xl font-black text-orange-600 dark:text-orange-400 tracking-wider leading-none sm:leading-tight">
        MONSTER ROLLER
      </a>

      <!-- Вот эта строка исправлена — теперь чёрный текст в светлой теме -->
      <div class="hidden lg:flex items-center gap-8 text-base font-bold !text-zinc-950 dark:!text-white hover:text-orange-600 dark:hover:text-orange-400 transition-colors">        
        <a href="/" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Home</a>
        <a href="/#book-your-ride" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Rent</a>
        <a href="/tours" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Tours</a>
        <a href="/about" class="hover:text-orange-500 dark:hover:text-orange-400 transition">About</a>
        <a href="/contact" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Contact</a>
      </div>

      <div class="flex shrink-0 items-center gap-2 sm:gap-4">
        <a href="https://wa.me/36302584709?text=I%20want%20to%20book%20a%20Monster%20Roller%20now!"
          class="bg-orange-500 hover:bg-orange-400 text-black dark:text-white font-bold whitespace-nowrap px-3 sm:px-7 md:px-8 py-2 sm:py-3 md:py-3.5 rounded-full shadow-lg text-xs sm:text-lg md:text-xl transition-all">
          Book Now
        </a>

        <button id="theme-toggle" class="day-night-toggle" aria-label="Toggle day and night mode" type="button">
          <span class="toggle-stars" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="toggle-clouds" aria-hidden="true">
            <span class="toggle-cloud c1"></span>
            <span class="toggle-cloud c2"></span>
          </span>
          <span class="toggle-thumb" aria-hidden="true">
            <span class="toggle-craters"></span>
          </span>
        </button>

        <button id="mobile-menu-btn" class="mobile-menu-toggle lg:hidden shrink-0" aria-label="Open menu" type="button" aria-expanded="false" aria-controls="mobile-menu-overlay">
          <span class="hamburger-lines" aria-hidden="true">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
          </span>
        </button>
      </div>
    </nav>
  </header>

  <div id="mobile-menu-overlay" class="mobile-menu-overlay" aria-hidden="true">
    <div class="mobile-menu-inner">
      <button id="mobile-menu-close" class="mobile-menu-close" type="button" aria-label="Close menu">
        <span></span>
