---
import '../styles/global.css';
const { title = "Monster Roller Budapest" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Syne:wght@800&display=swap" rel="stylesheet">
  <title>{title} – Ride the Beast!</title>
  <script defer src="/_vercel/insights/script.js"></script>
  <script defer src="/_vercel/speed-insights/script.js"></script>

  <script>
    // Ensure light mode is the default before anything renders
    const html = document.documentElement;
    const saved = localStorage.getItem('theme');
    
    // Always start with light unless explicitly saved as dark
    if (saved !== 'dark') {
      html.classList.add('light');
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      html.classList.remove('light');
    }
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header — кремовый по умолчанию -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-[#fffaf0] dark:bg-[#0f1419] backdrop-blur-xl border-b border-orange-300/50 dark:border-[#3d4a7a] shadow-lg transition-transform duration-300 will-change-transform">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-2xl sm:text-3xl font-black text-orange-600 dark:text-orange-400 tracking-wider">
        MONSTER ROLLER
      </a>

      <!-- Вот эта строка исправлена — теперь чёрный текст в светлой теме -->
      <div class="hidden lg:flex items-center gap-8 text-base font-bold !text-zinc-950 dark:!text-white hover:text-orange-600 dark:hover:text-orange-400 transition-colors">        
        <a href="/" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Home</a>
        <a href="/#book-your-ride" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Rent</a>
        <a href="/tours" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Tours</a>
        <a href="/about" class="hover:text-orange-500 dark:hover:text-orange-400 transition">About</a>
        <a href="/contact" class="hover:text-orange-500 dark:hover:text-orange-400 transition">Contact</a>
      </div>

      <div class="flex items-center gap-4">
        <a href="https://wa.me/36302584709?text=I%20want%20to%20book%20a%20Monster%20Roller%20now!"
          class="bg-orange-500 hover:bg-orange-400 text-black dark:text-white font-bold px-6 sm:px-7 md:px-8 py-3 sm:py-3 md:py-3.5 rounded-full shadow-lg text-base sm:text-lg md:text-xl transition-all">
          Book Now
        </a>

        <!-- Твоя кнопка солнца/луны (не трогал) -->
        <button id="theme-toggle" class="p-2.5 rounded-full hover:bg-orange-500/20 dark:hover:bg-zinc-800 transition">
          <svg id="sun-icon" class="w-6 h-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <circle cx="12" cy="12" r="5" />
            <line x1="12" y1="1" x2="12" y2="3" />
            <line x1="12" y1="21" x2="12" y2="23" />
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
            <line x1="1" y1="12" x2="3" y2="12" />
            <line x1="21" y1="12" x2="23" y2="12" />
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
          <svg id="moon-icon" class="w-6 h-6 text-yellow-300 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <button id="mobile-menu-btn" class="lg:hidden text-orange-600 dark:text-orange-400 text-3xl">☰</button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 right-0 bg-[#fffaf0] dark:bg-[#0f1419] border-b border-orange-300/50 dark:border-[#3d4a7a] shadow-lg py-4">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col gap-4">
        <a href="/" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Home</a>
        <a href="/#book-your-ride" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Rent</a>
        <a href="/tours" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Tours</a>
        <a href="/about" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">About</a>
        <a href="/contact" class="text-black dark:text-white font-semibold hover:text-orange-600 dark:hover:text-orange-400 transition py-2">Contact</a>
      </div>
    </div>
  </header>

  <main class="flex-1 pt-20 sm:pt-24">
    <slot />
  </main>

  <aside
    id="cookie-consent"
    class="fixed left-4 right-4 bottom-4 sm:left-6 sm:right-auto sm:max-w-sm z-[70] hidden translate-y-3 opacity-0 transition-all duration-300"
    aria-live="polite"
  >
    <div class="rounded-2xl border border-orange-300/60 dark:border-orange-500/30 bg-white/95 dark:bg-zinc-900/95 text-zinc-900 dark:text-zinc-100 backdrop-blur-xl shadow-2xl p-4">
      <div class="flex items-start gap-3">
        <div class="shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-300 dark:from-orange-500 dark:to-amber-300 flex items-center justify-center shadow-lg">
          <svg class="w-5 h-5 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 4h10a3 3 0 013 3v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7a3 3 0 013-3z"/>
            <circle cx="9" cy="9" r="1.2" fill="currentColor" stroke="none"/>
            <circle cx="15" cy="8.5" r="1" fill="currentColor" stroke="none"/>
            <circle cx="13" cy="14" r="1.3" fill="currentColor" stroke="none"/>
            <circle cx="8" cy="14.5" r="0.9" fill="currentColor" stroke="none"/>
            <circle cx="16" cy="16.5" r="0.9" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-bold text-zinc-900 dark:text-white text-sm">Cookie Notice</p>
          <p class="mt-1 text-xs leading-5 text-zinc-700 dark:text-zinc-300">We use cookies to improve site performance and your booking experience.</p>
        </div>
      </div>
      <div class="mt-3 flex items-center justify-end gap-2">
        <button id="cookie-decline" type="button" class="px-3 py-2 text-xs font-medium rounded-full border border-zinc-300 dark:border-zinc-600 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition">Later</button>
        <button id="cookie-accept" type="button" class="px-4 py-2 text-xs font-bold rounded-full bg-orange-500 hover:bg-orange-400 text-black transition">Accept Cookies</button>
      </div>
    </div>
  </aside>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Mobile Menu Toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close menu when a link is clicked
      const mobileMenuLinks = mobileMenu.querySelectorAll('a');
      mobileMenuLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });

      // Theme Toggle
      const toggle = document.getElementById('theme-toggle');
      const sun = document.getElementById('sun-icon');
      const moon = document.getElementById('moon-icon');
      const siteHeader = document.getElementById('site-header');
      const cookieConsent = document.getElementById('cookie-consent');
      const cookieAccept = document.getElementById('cookie-accept');
      const cookieDecline = document.getElementById('cookie-decline');
      let lastScrollY = window.scrollY;
      const COOKIE_KEY = 'mr_cookie_consent_v1';
      
      function setTheme(theme) {
        document.documentElement.classList.remove('dark', 'light');
        document.documentElement.classList.add(theme);
        
        if (theme === 'dark') {
          sun.classList.add('hidden');
          moon.classList.remove('hidden');
        } else {
          moon.classList.add('hidden');
          sun.classList.remove('hidden');
        }
        localStorage.setItem('theme', theme);
      }
      
      // Initialize icons based on current theme
      const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      if (currentTheme === 'dark') {
        sun.classList.add('hidden');
        moon.classList.remove('hidden');
      } else {
        moon.classList.add('hidden');
        sun.classList.remove('hidden');
      }
      
      toggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.contains('dark');
        setTheme(isDark ? 'light' : 'dark');
      });

      // Hide header on scroll down, show on scroll up
      window.addEventListener('scroll', () => {
        if (!siteHeader) return;

        const currentY = window.scrollY;
        const directionDelta = currentY - lastScrollY;

        if (currentY <= 10) {
          siteHeader.classList.remove('-translate-y-full');
          lastScrollY = currentY;
          return;
        }

        if (directionDelta > 8) {
          siteHeader.classList.add('-translate-y-full');
        } else if (directionDelta < -8) {
          siteHeader.classList.remove('-translate-y-full');
        }

        lastScrollY = currentY;
      }, { passive: true });

      function hideCookieBanner() {
        if (!cookieConsent) return;
        cookieConsent.classList.add('translate-y-3', 'opacity-0');
        setTimeout(() => cookieConsent.classList.add('hidden'), 300);
      }

      if (cookieConsent && !localStorage.getItem(COOKIE_KEY)) {
        cookieConsent.classList.remove('hidden');
        requestAnimationFrame(() => {
          cookieConsent.classList.remove('translate-y-3', 'opacity-0');
        });
      }

      if (cookieAccept) {
        cookieAccept.addEventListener('click', () => {
          localStorage.setItem(COOKIE_KEY, 'accepted');
          hideCookieBanner();
        });
      }

      if (cookieDecline) {
        cookieDecline.addEventListener('click', () => {
          localStorage.setItem(COOKIE_KEY, 'later');
          hideCookieBanner();
        });
      }
    });
  </script>
  <script defer src="/_vercel/insights/script.js"></script>
</body>
</html>