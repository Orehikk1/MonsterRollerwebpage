---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us — Monster Roller Budapest">
  <main class="about-page">
    <section class="about-hero">
      <div class="about-shell">
        <div class="about-hero-copy">
          <p class="about-label">Our Story</p>
          <h1 class="about-hero-title">
            <span class="hero-line">
              <span class="hero-word" style="--word-delay: 0s;">We</span>
              <span class="hero-word" style="--word-delay: 0.08s;">Live</span>
            </span>
            <span class="hero-line">
              <span class="hero-word" style="--word-delay: 0.16s;">For</span>
              <span class="hero-word" style="--word-delay: 0.24s;">This</span>
              <span class="hero-word" style="--word-delay: 0.32s;">City</span><span class="hero-word hero-dot" style="--word-delay: 0.4s;">.</span>
            </span>
          </h1>
          <p class="about-hero-text">
            Monster Roller Budapest was born from one simple idea — the best way to explore a city is to feel it, not just see it. We put you on the most powerful electric rollers in Budapest and let the city do the rest. Ancient streets, river views, hidden courtyards — all yours, at your own pace.
          </p>
        </div>
      </div>
      <div class="about-hero-number" aria-hidden="true">06</div>
    </section>

    <section class="about-stats animate-on-scroll" id="aboutStats">
      <div class="about-stats-grid">
        <article class="about-stat-item">
          <p class="about-stat-value"><span data-count="1000">0</span>+</p>
          <p class="about-stat-label">Happy Riders</p>
        </article>
        <article class="about-stat-item">
          <p class="about-stat-value"><span data-count="8">0</span>+</p>
          <p class="about-stat-label">Years in Budapest</p>
        </article>
        <article class="about-stat-item">
          <p class="about-stat-value"><span data-count="7">0</span></p>
          <p class="about-stat-label">Languages Spoken</p>
        </article>
        <article class="about-stat-item">
          <p class="about-stat-value"><span data-count="30">0</span>+</p>
          <p class="about-stat-label">Photo Stops Per Tour</p>
        </article>
      </div>
    </section>

    <section class="about-company">
      <div class="about-shell about-company-grid">
        <article class="about-quote-card animate-on-scroll">
          <p class="about-quote-mark">&quot;</p>
          <p class="about-quote-text">
            We don't run sightseeing tours. We create experiences that people talk about for years. Budapest is one of the most beautiful cities in Europe — and we know every single corner of it worth seeing.
          </p>
          <p class="about-quote-author">- Monster Roller Budapest Team</p>
        </article>

        <div class="about-company-copy">
          <p class="about-label animate-on-scroll">About The Company</p>
          <h2 class="about-section-title about-company-title animate-on-scroll">More Than Just a Ride</h2>
          <div class="about-company-text">
            <p class="animate-on-scroll">We are based right in the heart of Budapest at Haris köz 2, 1052 — a two minute walk from the Danube. Every session starts with a 15 to 20 minute hands-on training so complete beginners feel totally confident before we roll out.</p>
            <p class="animate-on-scroll">Our routes cover the full city — Fisherman's Bastion, the Parliament building, Buda Castle, Margaret Island, the Iron Shoes memorial, Liberty Bridge, and dozens of hidden spots that most tourists never find. All tours are available in 7 languages.</p>
            <p class="animate-on-scroll">Solo traveler, couple, family, or a big group — we have a route and a pace for everyone. Just show up, we handle everything else.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="about-gallery">
      <div class="about-gallery-shell">
        <div class="about-gallery-header animate-on-scroll">
          <p class="about-label">In Action</p>
          <h2 class="about-gallery-title">The Real Experience</h2>
          <p class="about-gallery-subtext">Every ride is different. Every rider leaves with a story.</p>
        </div>

        <div class="about-gallery-grid" aria-label="Monster Roller visual gallery">
          <div class="about-gallery-cell about-gallery-photo about-gallery-cell-1 animate-on-scroll" style="--stagger: 0s;" data-hover="Morning Ride - Chain Bridge"></div>

          <div class="about-gallery-cell about-gallery-photo about-gallery-cell-2 animate-on-scroll" style="--stagger: 0.05s;" data-hover="Fisherman's Bastion Views"></div>

          <div class="about-gallery-cell about-gallery-photo about-gallery-cell-3 animate-on-scroll" style="--stagger: 0.1s;" data-hover="Margaret Island Tour"></div>

          <div class="about-gallery-cell about-gallery-photo about-gallery-cell-4 animate-on-scroll" style="--stagger: 0.15s;" data-hover="Sunset at Parliament"></div>

          <div class="about-gallery-cell about-gallery-photo about-gallery-cell-5 animate-on-scroll" style="--stagger: 0.2s;" data-hover="Group Adventure"></div>

          <div class="about-gallery-cell about-gallery-cell-6 animate-on-scroll" style="--stagger: 0.25s;">
            <div class="about-gallery-marquee" aria-hidden="true">
              <div class="about-gallery-marquee-track">
                <span>Budapest · Chain Bridge · Fisherman's Bastion · Parliament · Buda Castle · Margaret Island · Iron Shoes · Liberty Bridge · Citadel · Danube · </span>
                <span>Budapest · Chain Bridge · Fisherman's Bastion · Parliament · Buda Castle · Margaret Island · Iron Shoes · Liberty Bridge · Citadel · Danube · </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="about-difference">
      <div class="about-shell">
        <p class="about-label animate-on-scroll">Why Choose Us</p>
        <h2 class="about-section-title about-difference-title animate-on-scroll">The Monster Roller Difference</h2>

        <div class="about-features-grid">
          <article class="about-feature-card animate-on-scroll" style="--stagger: 0s;">
            <svg class="about-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
            <h3>Eco-Friendly Adventure</h3>
            <p>Our electric rollers produce zero emissions. You explore one of Europe's most beautiful cities while leaving nothing behind. Adventure and responsibility in one ride.</p>
          </article>
          <article class="about-feature-card animate-on-scroll" style="--stagger: 0.1s;">
            <svg class="about-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
            <h3>7 Languages, One Team</h3>
            <p>Our guides speak English, Hungarian, German, French, Spanish, Italian, and Russian. No matter where you're from, your tour will feel personal and natural.</p>
          </article>
          <article class="about-feature-card animate-on-scroll" style="--stagger: 0.2s;">
            <svg class="about-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7h4l2-2h4l2 2h4v12H4z"/><circle cx="12" cy="13" r="3.2"/></svg>
            <h3>30+ Perfect Photo Spots</h3>
            <p>We know every perfect viewpoint, every golden hour angle, every spot the other tours skip. You leave with photos that make people stop scrolling.</p>
          </article>
          <article class="about-feature-card animate-on-scroll" style="--stagger: 0.3s;">
            <svg class="about-feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3z"/><path d="M9.5 12.5l1.8 1.8 3.5-3.5"/></svg>
            <h3>Safe For Everyone</h3>
            <p>Helmets provided, full training included, guides always within reach. Suitable for all ages and fitness levels. No experience needed — just show up.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="about-reviews">
      <div class="about-shell">
        <p class="about-label animate-on-scroll">What People Say</p>
        <h2 class="about-section-title about-reviews-title animate-on-scroll">Real Riders. Real Stories.</h2>

        <div class="about-reviews-row" aria-label="Customer reviews">
          <article class="about-review-card animate-on-scroll">
            <div class="about-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg>
            </div>
            <p class="about-review-text">"Absolutely incredible experience. Our guide was funny, knowledgeable, and so patient with us beginners. The views from Fisherman's Bastion at sunset were unreal. Best thing we did in Budapest by far."</p>
            <p class="about-review-name">Sarah M.</p>
            <p class="about-review-origin">London</p>
          </article>

          <article class="about-review-card animate-on-scroll">
            <div class="about-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg>
            </div>
            <p class="about-review-text">"Did the 3-hour grand tour as a group of 6 and every single one of us loved it. We saw so much more of the city than we ever would have on foot. The rollers are super easy once you get the hang of it."</p>
            <p class="about-review-name">Marco T.</p>
            <p class="about-review-origin">Rome</p>
          </article>

          <article class="about-review-card animate-on-scroll">
            <div class="about-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg>
            </div>
            <p class="about-review-text">"Booked last minute via WhatsApp and they sorted everything in 10 minutes. Professional, fun, and the route was perfectly planned. Parliament from the water's edge is something else entirely."</p>
            <p class="about-review-name">Anna K.</p>
            <p class="about-review-origin">Berlin</p>
          </article>

          <article class="about-review-card animate-on-scroll">
            <div class="about-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg>
            </div>
            <p class="about-review-text">"The guides really know their stuff - history, architecture, hidden stories. It's not just a ride, it's a proper tour. Highly recommend the 90-minute Fisherman's Bastion route for first visits."</p>
            <p class="about-review-name">James R.</p>
            <p class="about-review-origin">New York</p>
          </article>

          <article class="about-review-card animate-on-scroll">
            <div class="about-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg>
            </div>
            <p class="about-review-text">"Perfect for families. My kids (12 and 15) absolutely loved it and felt safe the whole time. The training at the start is very thorough. We'll definitely book again next time we're in Budapest."</p>
            <p class="about-review-name">Claire D.</p>
            <p class="about-review-origin">Paris</p>
          </article>

          <article class="about-review-card animate-on-scroll">
            <div class="about-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 17l-5.9 3 1.2-6.5L2.5 8.9l6.6-.9L12 2z"/></svg>
            </div>
            <p class="about-review-text">"One of the most unique ways to explore a city I've ever experienced. The eco-friendly aspect is a nice bonus too. Monster Roller is the real deal - skip the hop-on hop-off bus and do this instead."</p>
            <p class="about-review-name">Tomas V.</p>
            <p class="about-review-origin">Madrid</p>
          </article>
        </div>
      </div>
    </section>

    <section class="about-cta-wrap">
      <div class="about-shell">
        <div class="about-cta-card animate-on-scroll">
          <div class="about-cta-copy">
            <h2 class="about-cta-title">Ready to Ride?</h2>
            <p>Over 1,000 riders have already seen Budapest our way. Come find out why they keep coming back.</p>
          </div>
          <div class="about-cta-actions">
            <a href="https://wa.me/36302584709" target="_blank" rel="noopener noreferrer" class="about-btn about-btn-primary">Book via WhatsApp -></a>
            <a href="/tours" class="about-btn about-btn-ghost">View All Tours -></a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    .about-page {
      background: #0d0d0d;
      color: #ffffff;
      font-family: 'DM Sans', sans-serif;
    }

    .about-shell {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 60px;
      position: relative;
    }

    .about-label {
      margin: 0;
      color: #f97316;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .about-section-title {
      margin: 14px 0 0;
      font-family: 'Syne', sans-serif;
      font-size: 48px;
      line-height: 1.05;
      font-weight: 800;
      color: #ffffff;
    }

    .about-hero {
      position: relative;
      width: 100%;
      padding: 120px 0 80px;
      overflow: hidden;
    }

    .about-hero-copy {
      width: 60%;
      text-align: left;
      position: relative;
      z-index: 2;
    }

    .about-hero-title {
      margin: 18px 0 0;
      font-family: 'Syne', sans-serif;
      font-size: 88px;
      font-weight: 900;
      line-height: 0.95;
      color: #ffffff;
      letter-spacing: -0.02em;
    }

    .hero-line {
      display: block;
    }

    .hero-word {
      display: inline-block;
      margin-right: 0.32em;
      opacity: 0;
      transform: translateY(40px);
      animation: heroWordIn 0.7s ease forwards;
      animation-delay: var(--word-delay, 0s);
    }

    .hero-word:last-child {
      margin-right: 0;
    }

    .hero-dot {
      color: #f97316;
      margin-right: 0;
    }

    .about-hero-text {
      margin: 28px 0 0;
      max-width: 480px;
      font-size: 16px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.65);
    }

    .about-hero-number {
      position: absolute;
      right: 60px;
      top: 80px;
      width: 40%;
      text-align: right;
      font-family: 'Syne', sans-serif;
      font-size: 180px;
      line-height: 1;
      font-weight: 900;
      color: rgba(255, 255, 255, 0.03);
      pointer-events: none;
      user-select: none;
    }

    .about-stats {
      width: 100%;
      background: #111111;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding: 50px 60px;
    }

    .about-stats-grid {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 22px;
    }

    .about-stat-item {
      text-align: center;
    }

    .about-stat-value {
      margin: 0;
      font-family: 'Syne', sans-serif;
      font-size: 52px;
      line-height: 1;
      font-weight: 800;
      color: #f97316;
    }

    .about-stat-label {
      margin: 10px 0 0;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.5);
    }

    .about-company {
      padding: 80px 0;
    }

    .about-company-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }

    .about-quote-card {
      background: #111111;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.07);
      padding: 40px;
      position: relative;
    }

    .about-quote-mark {
      margin: 0;
      font-family: 'Syne', sans-serif;
      font-size: 120px;
      line-height: 0.72;
      color: #f97316;
    }

    .about-quote-text {
      margin: 10px 0 0;
      font-size: 20px;
      line-height: 1.6;
      font-style: italic;
      color: #ffffff;
    }

    .about-quote-author {
      margin: 20px 0 0;
      font-size: 13px;
      color: #f97316;
      letter-spacing: 0.02em;
    }

    .about-company-title {
      font-size: 36px;
      margin-top: 12px;
    }

    .about-company-text {
      margin-top: 20px;
      display: grid;
      gap: 16px;
    }

    .about-company-text p {
      margin: 0;
      font-size: 15px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.65);
    }

    .about-gallery {
      width: 100%;
      padding: 80px 0;
      background: transparent;
    }

    .about-gallery-shell {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 60px;
    }

    .about-gallery-header {
      margin-bottom: 48px;
      text-align: left;
    }

    .about-gallery-title {
      margin: 14px 0 0;
      font-family: 'Syne', sans-serif;
      font-size: 44px;
      line-height: 1.05;
      font-weight: 800;
      color: #ffffff;
    }

    .about-gallery-subtext {
      margin: 12px 0 0;
      max-width: 500px;
      font-size: 14px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.5);
    }

    .about-gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 16px;
      grid-auto-rows: minmax(90px, auto);
    }

    .about-gallery-cell {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
    }

    .about-gallery-photo {
      isolation: isolate;
      transition: transform 0.4s ease;
    }

    .about-gallery-photo:hover {
      transform: scale(1.02);
    }

    .about-gallery-photo::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0) 45%, rgba(0, 0, 0, 0.4) 100%);
      pointer-events: none;
    }

    .about-gallery-photo::after {
