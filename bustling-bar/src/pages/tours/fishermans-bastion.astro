---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Fisherman's Bastion Tour — 90 Min · Monster Roller Budapest">
  <section class="fb-hero">
    <div class="fb-hero-bg fb-hero-bg-main" aria-hidden="true"></div>
    <div class="fb-hero-bg fb-hero-bg-overlay" aria-hidden="true"></div>
    <div class="fb-hero-bg fb-hero-bg-glow" aria-hidden="true"></div>

    <div class="fb-hero-content">
      <div class="fb-hero-left">
        <nav class="fb-breadcrumb" aria-label="Breadcrumb">
          <a href="/tours">Tours</a>
          <span aria-hidden="true"> → </span>
          <span>Fisherman's Bastion</span>
        </nav>

        <div class="fb-badges fb-fade-up" style="--delay: 0.08s;">
          <span class="fb-badge fb-badge-popular">Most Popular</span>
          <span class="fb-badge">90 Minutes</span>
        </div>

        <h1 class="fb-hero-title">
          <span class="fb-title-line" style="--delay: 0.14s;">Fisherman's</span>
          <span class="fb-title-line" style="--delay: 0.24s;">Bastion Tour</span>
        </h1>

        <div class="fb-quick-pills fb-fade-up" style="--delay: 0.34s;">
          <span>📍 Elizabeth Bridge</span>
          <span>🏰 Buda Castle</span>
          <span>🌉 Chain Bridge</span>
          <span>📸 20 Photospots</span>
        </div>

        <p class="fb-price fb-fade-up" style="--delay: 0.44s;">
          <span class="fb-price-from">from</span>
          <span class="fb-price-value">€49</span>
          <span class="fb-price-from">per person</span>
        </p>
      </div>

      <aside class="fb-hero-card fb-fade-in-right" style="--delay: 0.3s;" aria-label="Quick tour info">
        <p class="fb-card-eyebrow">Quick Info</p>
        <div class="fb-info-list">
          <div class="fb-info-row"><span>Duration</span><strong>90 min + 15 min training</strong></div>
          <div class="fb-info-row"><span>Departure</span><strong>Haris koz 2, 1052 Budapest</strong></div>
          <div class="fb-info-row"><span>Group Language</span><strong>English</strong></div>
          <div class="fb-info-row"><span>Private Language</span><strong>EN / DE / RU / ES / FR</strong></div>
          <div class="fb-info-row"><span>Min Age</span><strong>8 years old</strong></div>
        </div>
        <a class="fb-book-hero" href="#booking">Book This Tour →</a>
      </aside>
    </div>

    <a href="#highlights" class="fb-scroll-indicator" aria-label="Scroll to highlights">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>

  <section class="fb-strip" id="highlights" aria-label="Visual highlights">
    <button class="fb-panel panel-1 is-active" type="button" data-panel="0">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 18h18M5 18l4-7 4 4 3-5 3 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Elizabeth Bridge</span>
    </button>
    <button class="fb-panel panel-2" type="button" data-panel="1">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 18h18M5 18l4-7 4 4 3-5 3 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Chain Bridge</span>
    </button>
    <button class="fb-panel panel-3" type="button" data-panel="2">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 18h18M5 18l4-7 4 4 3-5 3 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Fisherman's Bastion</span>
    </button>
    <button class="fb-panel panel-4" type="button" data-panel="3">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 18h18M5 18l4-7 4 4 3-5 3 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Buda Castle</span>
    </button>
    <button class="fb-panel panel-5" type="button" data-panel="4">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 18h18M5 18l4-7 4 4 3-5 3 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Castle District</span>
    </button>
  </section>

  <section class="fb-about-tour">
    <div class="fb-about-grid">
      <div class="fb-about-left">
        <p class="fb-kicker">The Experience</p>
        <h2>What Makes This Tour Special</h2>
        <span class="fb-line" aria-hidden="true"></span>
        <p>
          Start in the heart of Pest and glide across the iconic Elisabeth Bridge — the White Bridge — with panoramic views of the Danube stretching in both directions. On the Buda side, the city transforms completely. Medieval streets, Baroque facades, and Gothic towers rise above you as you ride up through the Castle District. You will visit the Zero Kilometer Stone, pass through the Castle Garden, and arrive at Fisherman's Bastion — one of the most photographed spots in all of Europe — before finishing at the legendary Buda Castle itself. This is not just a sightseeing route. It is a 90-minute immersion into 1,000 years of Hungarian history.
        </p>
        <a class="fb-back-btn" href="/tours">← Back to All Tours</a>
      </div>

      <div class="fb-about-right">
        <article class="fb-info-card">
          <p class="fb-card-title">Sights You'll Visit</p>
          <div class="fb-tag-grid">
            <span>Elizabeth Bridge</span>
            <span>Castle Garden</span>
            <span>Chain Bridge</span>
            <span>Zero Kilometer</span>
            <span>Fisherman's Bastion</span>
            <span>Matthias Church</span>
            <span>Buda Castle</span>
            <span>Danube Panorama</span>
          </div>
        </article>

        <article class="fb-info-card">
          <p class="fb-card-title">What's Included</p>
          <ul class="fb-list fb-list-check">
            <li>Live guide with commentary</li>
            <li>Safety training and test drive</li>
            <li>Photo assistance throughout</li>
            <li>Helmets in all sizes</li>
            <li>Raincoats and gloves if needed</li>
          </ul>
        </article>

        <article class="fb-info-card">
          <p class="fb-card-title">Good to Know</p>
          <ul class="fb-list fb-list-info">
            <li>Minimum age 8 years old</li>
            <li>Minimum weight 35 kg</li>
            <li>Not suitable during pregnancy</li>
            <li>Groups split into max 8 riders per guide</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="fb-booking" id="booking">
    <div class="fb-booking-shell">
      <p class="fb-kicker">Reserve Your Spot</p>
      <h2>Book the Fisherman's Bastion Tour</h2>
      <p class="fb-booking-subtext">Secure your spot now — pay on arrival. Free cancellation up to 24h before.</p>

      <div class="fb-booking-card">
        <div class="fb-steps" aria-label="Booking steps">
          <div class="fb-step is-active">
            <span>1</span>
            <p>Tour Options</p>
          </div>
          <div class="fb-step-line" aria-hidden="true"></div>
          <div class="fb-step is-future">
            <span>2</span>
            <p>Your Details</p>
          </div>
          <div class="fb-step-line" aria-hidden="true"></div>
          <div class="fb-step is-future">
            <span>3</span>
            <p>Summary</p>
          </div>
        </div>

        <form id="fbTourForm" class="fb-form" action="javascript:void(0)">
          <div class="fb-step-pane is-active" data-step-pane="1">
            <div class="fb-field-group">
              <label class="fb-label">Tour Type</label>
              <div class="fb-type-grid" role="radiogroup" aria-label="Tour type">
                <button class="fb-type-card is-selected" type="button" data-type="group" role="radio" aria-checked="true">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M16 19v-1a4 4 0 00-4-4H7a4 4 0 00-4 4v1M9.5 11a3 3 0 100-6 3 3 0 000 6zm7.5 1a3 3 0 100-6 3 3 0 000 6zm4 8v-1a4 4 0 00-3-3.87" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <strong>Group Tour</strong>
                  <em>from €49 / person</em>
                </button>
                <button class="fb-type-card" type="button" data-type="private" role="radio" aria-checked="false">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <strong>Private Tour</strong>
                  <em>from €59 / person</em>
                </button>
              </div>
            </div>

            <div class="fb-field-group">
              <label class="fb-label" for="fbDate">Date</label>
              <input id="fbDate" class="fb-input" type="date" required />
            </div>

            <div class="fb-field-group" id="groupTimeWrap">
              <label class="fb-label">Time Slot</label>
              <div class="fb-time-pills" role="radiogroup" aria-label="Group time slots">
                <button class="fb-time-pill is-active" type="button" data-time="08:30">08:30</button>
                <button class="fb-time-pill" type="button" data-time="10:00">10:00</button>
                <button class="fb-time-pill" type="button" data-time="11:30">11:30</button>
                <button class="fb-time-pill" type="button" data-time="13:00">13:00</button>
                <button class="fb-time-pill" type="button" data-time="15:00">15:00</button>
              </div>
            </div>

            <div class="fb-field-group fb-hidden" id="privateTimeWrap">
              <label class="fb-label" for="fbPrivateTime">Choose Any Time</label>
              <input id="fbPrivateTime" class="fb-input" type="time" value="10:00" />
              <p class="fb-help">We'll confirm availability within 30 minutes.</p>
            </div>

            <div class="fb-field-group">
              <label class="fb-label">Participants</label>
              <div class="fb-stepper" aria-label="Participants stepper">
                <button id="fbMinus" type="button" aria-label="Decrease participants">−</button>
                <span id="fbParticipants" aria-live="polite">2</span>
                <button id="fbPlus" type="button" aria-label="Increase participants">+</button>
              </div>
            </div>

            <div class="fb-field-group">
              <label class="fb-label">Tour Language</label>
              <div id="fbLanguageGroup" class="fb-lang-single">🇬🇧 English</div>
              <div id="fbLanguagePrivate" class="fb-lang-row fb-hidden" aria-label="Private tour languages">
                <span>EN</span><span>DE</span><span>RU</span><span>ES</span><span>FR</span>
              </div>
            </div>

            <div class="fb-price-summary">
              <p>Total</p>
              <strong id="fbTotal">€98</strong>
              <p id="fbBreakdown">2 participants × €49 = €98</p>
            </div>
          </div>

          <div class="fb-step-pane" data-step-pane="2">
            <div class="fb-field-group">
              <label class="fb-label" for="fbFullName">Full Name</label>
              <input id="fbFullName" class="fb-input" type="text" placeholder="Your name" required />
            </div>

            <div class="fb-field-group">
              <label class="fb-label" for="fbEmail">Email</label>
              <input id="fbEmail" class="fb-input" type="email" placeholder="name@email.com" required />
            </div>

            <div class="fb-field-group">
              <label class="fb-label" for="fbPhone">Phone / WhatsApp</label>
              <input id="fbPhone" class="fb-input" type="tel" placeholder="+36..." required />
            </div>

            <div class="fb-field-group">
              <label class="fb-label" for="fbNote">Notes (optional)</label>
              <textarea id="fbNote" class="fb-input fb-textarea" rows="4" placeholder="Any special requests?"></textarea>
            </div>
          </div>

          <div class="fb-step-pane" data-step-pane="3">
            <div class="fb-final-summary">
              <div class="fb-summary-row"><span>Tour Type</span><strong id="fbSummaryType">Group Tour</strong></div>
              <div class="fb-summary-row"><span>Date</span><strong id="fbSummaryDate">-</strong></div>
              <div class="fb-summary-row"><span>Time</span><strong id="fbSummaryTime">-</strong></div>
              <div class="fb-summary-row"><span>Participants</span><strong id="fbSummaryParticipants">2</strong></div>
              <div class="fb-summary-row"><span>Name</span><strong id="fbSummaryName">-</strong></div>
              <div class="fb-summary-row"><span>Phone</span><strong id="fbSummaryPhone">-</strong></div>
              <div class="fb-summary-row"><span>Total</span><strong id="fbSummaryTotal" class="fb-summary-total">€98</strong></div>
            </div>
          </div>

          <div class="fb-form-actions">
            <button id="fbBackBtn" class="fb-secondary-btn fb-hidden" type="button">← Back</button>
            <button id="fbNextBtn" class="fb-primary-btn" type="button">Next: Your Details →</button>
          </div>

          <p id="fbFormNotice" class="fb-form-notice fb-hidden" aria-live="polite"></p>

          <button id="fbChatBtn" class="fb-chat-btn fb-hidden" type="button">Or chat with us on WhatsApp</button>

          <div id="fbTrustRow" class="fb-trust-row fb-hidden" aria-label="Booking trust badges">
            <span>
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Free cancellation 24h
            </span>
            <span>
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v20M2 12h20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Pay on arrival
            </span>
            <span>
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 4v5c0 5-3.5 7.7-7 9-3.5-1.3-7-4-7-9V7l7-4z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Instant confirmation
            </span>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="fb-more">
    <div class="fb-more-shell">
      <h2>Explore More Routes</h2>
      <p>Not what you're looking for? We have 4 more tours across Budapest.</p>
      <a href="/tours" class="fb-more-link">View All Tours →</a>

      <div class="fb-mini-row" aria-label="Other tours">
        <article class="fb-mini-card">
          <h3>Citadella</h3>
          <p class="fb-mini-price">€35</p>
          <p class="fb-mini-time">60 minutes</p>
          <a href="/tours">View Tour</a>
        </article>
        <article class="fb-mini-card">
          <h3>Buda + Pest</h3>
          <p class="fb-mini-price">€59</p>
          <p class="fb-mini-time">120 minutes</p>
          <a href="/tours">View Tour</a>
        </article>
        <article class="fb-mini-card">
          <h3>Grand Tour</h3>
          <p class="fb-mini-price">€69</p>
          <p class="fb-mini-time">180 minutes</p>
          <a href="/tours">View Tour</a>
        </article>
        <article class="fb-mini-card fb-mini-card-rent">
          <h3>Freestyle Rent</h3>
          <p class="fb-mini-price">from €25</p>
          <p class="fb-mini-time">Ride your own route</p>
          <a href="/#book-your-ride">Rent Now</a>
        </article>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const panelButtons = Array.from(document.querySelectorAll('.fb-panel'));
      panelButtons.forEach((panel) => {
        panel.addEventListener('click', () => {
          panelButtons.forEach((btn) => btn.classList.remove('is-active'));
          panel.classList.add('is-active');
        });
      });

      const stepItems = Array.from(document.querySelectorAll('.fb-step'));
      const stepPanes = Array.from(document.querySelectorAll('[data-step-pane]'));
      const typeCards = Array.from(document.querySelectorAll('.fb-type-card'));
      const timePills = Array.from(document.querySelectorAll('.fb-time-pill'));
      const groupTimeWrap = document.getElementById('groupTimeWrap');
      const privateTimeWrap = document.getElementById('privateTimeWrap');
      const privateTimeInput = document.getElementById('fbPrivateTime');
      const dateInput = document.getElementById('fbDate');
      const fullNameInput = document.getElementById('fbFullName');
      const emailInput = document.getElementById('fbEmail');
      const phoneInput = document.getElementById('fbPhone');
      const noteInput = document.getElementById('fbNote');
      const minusBtn = document.getElementById('fbMinus');
      const plusBtn = document.getElementById('fbPlus');
      const participantsEl = document.getElementById('fbParticipants');
      const totalEl = document.getElementById('fbTotal');
      const breakdownEl = document.getElementById('fbBreakdown');
      const summaryTypeEl = document.getElementById('fbSummaryType');
      const summaryDateEl = document.getElementById('fbSummaryDate');
      const summaryTimeEl = document.getElementById('fbSummaryTime');
      const summaryParticipantsEl = document.getElementById('fbSummaryParticipants');
      const summaryNameEl = document.getElementById('fbSummaryName');
      const summaryPhoneEl = document.getElementById('fbSummaryPhone');
      const summaryTotalEl = document.getElementById('fbSummaryTotal');
      const backBtn = document.getElementById('fbBackBtn');
      const nextBtn = document.getElementById('fbNextBtn');
      const formNotice = document.getElementById('fbFormNotice');
      const chatBtn = document.getElementById('fbChatBtn');
      const trustRow = document.getElementById('fbTrustRow');
      const langGroup = document.getElementById('fbLanguageGroup');
      const langPrivate = document.getElementById('fbLanguagePrivate');

      let selectedType = 'group';
      let selectedTime = '08:30';
      let participants = 2;
      let currentStep = 1;

      const formatDateForMessage = (value) => {
        if (!value) return 'not selected';
        const [y, m, d] = value.split('-');
        return `${d}.${m}.${y}`;
      };

      const getUnitPrice = () => selectedType === 'group' ? 49 : 59;

      const isValidEmail = (value) => /.+@.+\..+/.test(value);

      const setTodayMinDate = () => {
        const now = new Date();
        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        const today = `${year}-${month}-${day}`;
        dateInput.min = today;
        if (!dateInput.value) {
          dateInput.value = today;
        }
      };

      const updateTotal = () => {
        const unitPrice = getUnitPrice();
        const total = participants * unitPrice;
        totalEl.textContent = `€${total}`;
        breakdownEl.textContent = `${participants} participants × €${unitPrice} = €${total}`;
      };

      const updateTypeUI = () => {
        typeCards.forEach((card) => {
          const isSelected = card.dataset.type === selectedType;
          card.classList.toggle('is-selected', isSelected);
          card.setAttribute('aria-checked', String(isSelected));
        });

        const isGroup = selectedType === 'group';
        groupTimeWrap.classList.toggle('fb-hidden', !isGroup);
        privateTimeWrap.classList.toggle('fb-hidden', isGroup);
        langGroup.classList.toggle('fb-hidden', !isGroup);
        langPrivate.classList.toggle('fb-hidden', isGroup);
        updateTotal();
      };

      const getSelectedTime = () => {
        if (selectedType === 'group') return selectedTime;
        return privateTimeInput && privateTimeInput.value ? privateTimeInput.value : 'not selected';
      };

      const validateStepOne = () => {
        if (!dateInput.value) return false;
        if (selectedType === 'group') return Boolean(selectedTime);
        return Boolean(privateTimeInput && privateTimeInput.value);
      };

      const validateStepTwo = () => {
        const nameOk = Boolean(fullNameInput && fullNameInput.value.trim());
        const emailOk = Boolean(emailInput && isValidEmail(emailInput.value.trim()));
        const phoneOk = Boolean(phoneInput && phoneInput.value.trim());
        return nameOk && emailOk && phoneOk;
      };

      const updateSummary = () => {
        const dateText = formatDateForMessage(dateInput.value);
        const timeText = getSelectedTime();
        const unitPrice = getUnitPrice();
        const total = participants * unitPrice;
        summaryTypeEl.textContent = selectedType === 'group' ? 'Group Tour' : 'Private Tour';
        summaryDateEl.textContent = dateText;
        summaryTimeEl.textContent = timeText;
        summaryParticipantsEl.textContent = String(participants);
        summaryNameEl.textContent = fullNameInput.value.trim() || '-';
        summaryPhoneEl.textContent = phoneInput.value.trim() || '-';
        summaryTotalEl.textContent = `€${total}`;
      };

      const setStep = (step) => {
        currentStep = Math.max(1, Math.min(3, step));

        stepPanes.forEach((pane) => {
          const paneStep = Number(pane.getAttribute('data-step-pane'));
          pane.classList.toggle('is-active', paneStep === currentStep);
        });

        stepItems.forEach((item, index) => {
          const stepIndex = index + 1;
          item.classList.toggle('is-active', stepIndex === currentStep);
          item.classList.toggle('is-complete', stepIndex < currentStep);
          item.classList.toggle('is-future', stepIndex > currentStep);
          const badge = item.querySelector('span');
          if (badge) {
            badge.textContent = stepIndex < currentStep ? '✓' : String(stepIndex);
          }
        });

        backBtn.classList.toggle('fb-hidden', currentStep === 1);
        chatBtn.classList.toggle('fb-hidden', currentStep !== 3);
        trustRow.classList.toggle('fb-hidden', currentStep !== 3);

        if (currentStep === 1) {
          nextBtn.textContent = 'Next: Your Details →';
        } else if (currentStep === 2) {
          nextBtn.textContent = 'Next: Summary →';
        } else {
          nextBtn.textContent = 'Book Now →';
          updateSummary();
        }
      };

      const buildWhatsAppUrl = () => {
        const dateText = formatDateForMessage(dateInput.value);
        const timeText = getSelectedTime();
        const typeText = selectedType === 'group' ? 'group' : 'private';
        const total = participants * getUnitPrice();
        const fullName = fullNameInput.value.trim() || '-';
        const email = emailInput.value.trim() || '-';
        const phone = phoneInput.value.trim() || '-';
        const note = noteInput.value.trim() || 'None';
        const message = `I want to book the Fisherman's Bastion Tour. Name: ${fullName}. Email: ${email}. Phone: ${phone}. Date: ${dateText}. Time: ${timeText}. Participants: ${participants}. Type: ${typeText}. Total: €${total}. Notes: ${note}`;
        return `https://wa.me/36302584709?text=${encodeURIComponent(message)}`;
      };

      stepItems.forEach((item, index) => {
        item.addEventListener('click', () => {
          const nextStep = index + 1;
          if (nextStep === 3 && !validateStepTwo()) {
            setStep(2);
            return;
          }
          setStep(nextStep);
        });
      });

      typeCards.forEach((card) => {
        card.addEventListener('click', () => {
          selectedType = card.dataset.type || 'group';
          updateTypeUI();
        });
      });

      timePills.forEach((pill) => {
        pill.addEventListener('click', () => {
          timePills.forEach((p) => p.classList.remove('is-active'));
          pill.classList.add('is-active');
          selectedTime = pill.dataset.time || '08:30';
        });
      });

      minusBtn.addEventListener('click', () => {
        participants = Math.max(1, participants - 1);
        participantsEl.textContent = String(participants);
        updateTotal();
      });

      plusBtn.addEventListener('click', () => {
        participants = Math.min(15, participants + 1);
        participantsEl.textContent = String(participants);
        updateTotal();
      });

      backBtn.addEventListener('click', () => {
        setStep(currentStep - 1);
      });

      nextBtn.addEventListener('click', () => {
        if (formNotice) {
          formNotice.textContent = '';
          formNotice.classList.add('fb-hidden');
        }

        if (currentStep === 1) {
          if (!validateStepOne()) return;
          setStep(2);
          return;
        }

        if (currentStep === 2) {
          if (!validateStepTwo()) return;
          setStep(3);
          return;
        }

        if (formNotice) {
          formNotice.textContent = 'Booking captured. Email confirmation integration will be connected next. For instant support, use WhatsApp below.';
          formNotice.classList.remove('fb-hidden');
        }
      });

      chatBtn.addEventListener('click', () => {
        window.open(buildWhatsAppUrl(), '_blank', 'noopener,noreferrer');
