    .fb-fade-up {
      opacity: 0;
      transform: translateY(30px);
      animation: fadeSlideUp 0.7s ease forwards;
      animation-delay: var(--delay);
    }

    .fb-fade-in-right {
      opacity: 0;
      transform: translateX(30px);
      animation: fadeSlideUp 0.7s ease forwards;
      animation-delay: var(--delay);
    }

    @keyframes heroGlow {
      from { transform: scale(1); }
      to { transform: scale(1.15); }
    }

