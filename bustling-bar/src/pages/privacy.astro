---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy">
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-4xl font-black text-orange-500 mb-12">Privacy Policy</h1>
      <p class="text-gray-300 mb-8">
        We use cookies to improve your experience on our website, for analytics, and personalization. 
        By accepting cookies, you agree to their use in accordance with this policy.
      </p>
      <p class="text-gray-300 mb-8">
        We do not sell your personal data. All data is used only for the operation of the site and booking requests.
      </p>
      <p class="text-gray-400 text-sm">
        Last updated: February 21, 2026
      </p>
    </div>
  </section>
</Layout>