        font-size: 36px;
      }

      .ftf-stat-card {
        padding: 18px;
      }

      .ftf-stat-value {
        font-size: 32px;
      }

      .ftf-stat-value-sm {
        font-size: 29px;
      }

      .ftf-faq-question {
        font-size: 15px;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.getElementById('ftfFaqList');
      if (!root) return;

      const items = Array.from(root.querySelectorAll('.ftf-faq-item'));
      const closeAll = () => {
        items.forEach((item) => {
          item.classList.remove('open');
          const button = item.querySelector('.ftf-faq-question');
          if (button) button.setAttribute('aria-expanded', 'false');
        });
      };

      items.forEach((item) => {
        const question = item.querySelector('.ftf-faq-question');
        if (!question) return;

        question.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          closeAll();

          if (!isOpen) {
            item.classList.add('open');
            question.setAttribute('aria-expanded', 'true');
          }
        });
      });
    })();
  </script>

  <!-- JavaScript -->
  <script>
    const singleBtn = document.getElementById('singleBtn');
    const doubleBtn = document.getElementById('doubleBtn');
    const peopleInput = document.getElementById('people');
    const priceDisplay = document.getElementById('totalPrice');
    const dateInput = document.getElementById('date');
    const hoursSelect = document.getElementById('hours');
    const timeInput = document.getElementById('time');
    const rollerImage = document.getElementById('rollerImage');
    
    let isDouble = false;

    const SINGLE_SEAT = { base: 25, extra: 10, image: "/images/single-seat.jpg" };
    const DOUBLE_SEAT = { base: 35, extra: 15, image: "/images/double-seat.jpg" };

    function setTodayMinDate() {
      if (!(dateInput instanceof HTMLInputElement)) return;

      const now = new Date();
      const year = now.getFullYear();
      const month = String(now.getMonth() + 1).padStart(2, '0');
      const day = String(now.getDate()).padStart(2, '0');
      const today = `${year}-${month}-${day}`;

      dateInput.min = today;

      if (!dateInput.value || dateInput.value < today) {
        dateInput.value = today;
      }
    }

    function updatePrice() {
      const hours = parseInt(hoursSelect.value) || 1;
      const people = parseInt(peopleInput.value) || 1;
      
      const { base, extra } = isDouble ? DOUBLE_SEAT : SINGLE_SEAT;
      const totalPerRoller = base + (hours - 1) * extra;
      const total = totalPerRoller * people;

      priceDisplay.textContent = `${total} €`;
      
      // Re-trigger pulse without forcing synchronous layout.
      priceDisplay.classList.remove('animate-pulse-slow');
      requestAnimationFrame(() => {
        priceDisplay.classList.add('animate-pulse-slow');
      });
    }

    function setRollerType(isDoubleSeat) {
      isDouble = isDoubleSeat;
      const { image } = isDouble ? DOUBLE_SEAT : SINGLE_SEAT;
      
      if (isDoubleSeat) {
        doubleBtn.classList.add('active', 'border-orange-500', 'bg-orange-500/10', 'dark:bg-orange-600/20');
        singleBtn.classList.remove('active', 'border-orange-500', 'bg-orange-500/10', 'dark:bg-orange-600/20');
      } else {
        singleBtn.classList.add('active', 'border-orange-500', 'bg-orange-500/10', 'dark:bg-orange-600/20');
        doubleBtn.classList.remove('active', 'border-orange-500', 'bg-orange-500/10', 'dark:bg-orange-600/20');
      }
      
      rollerImage.src = image;
      updatePrice();
    }

    singleBtn.addEventListener('click', () => setRollerType(false));
    doubleBtn.addEventListener('click', () => setRollerType(true));
    hoursSelect.addEventListener('change', updatePrice);
    peopleInput.addEventListener('input', updatePrice);

    timeInput.addEventListener('focus', () => {
      if (!timeInput.value) timeInput.value = '10:00';
    });

    timeInput.addEventListener('change', () => {
      const time = timeInput.value;
      if (time && (time < '10:00' || time > '18:00')) {
        timeInput.value = time < '10:00' ? '10:00' : '18:00';
      }
    });

    setTodayMinDate();
    updatePrice();

    const sessionSlider = document.getElementById('sessionSlider');
    const sessionCards = sessionSlider ? Array.from(sessionSlider.querySelectorAll('.session-card')) : [];
    const sessionDots = Array.from(document.querySelectorAll('.session-dot'));
    const prevBtn = document.getElementById('sessionPrev');
    const nextBtn = document.getElementById('sessionNext');
    const defaultSessionIndex = 2;
    let activeSessionIndex = defaultSessionIndex;
    let isProgrammaticScroll = false;
    let programmaticScrollTimer;
    let isInitialSelectionLock = true;

    function setActiveSession(index) {
      activeSessionIndex = index;
      sessionCards.forEach((card, cardIndex) => {
        card.classList.toggle('is-active', cardIndex === index);
      });
      sessionDots.forEach((dot, dotIndex) => {
        dot.classList.toggle('is-active', dotIndex === index);
      });
    }

    function centerCard(index, smooth = true) {
      const card = sessionCards[index];
      if (!card || !sessionSlider) return;
      const sliderRect = sessionSlider.getBoundingClientRect();
      const cardRect = card.getBoundingClientRect();
      const sliderCenterX = sliderRect.left + sliderRect.width / 2;
      const cardCenterX = cardRect.left + cardRect.width / 2;
      const delta = cardCenterX - sliderCenterX;
      const targetLeft = sessionSlider.scrollLeft + delta;

      if (smooth) {
        isProgrammaticScroll = true;
        clearTimeout(programmaticScrollTimer);
      }

      sessionSlider.scrollTo({
        left: Math.max(0, targetLeft),
        behavior: smooth ? 'smooth' : 'auto'
      });

      if (smooth) {
        programmaticScrollTimer = setTimeout(() => {
          isProgrammaticScroll = false;
          setActiveSession(index);
        }, 420);
      }
    }

    function bindSessionEvents() {
      if (!sessionSlider || sessionCards.length === 0) return;

      sessionCards.forEach((card, index) => {
        card.addEventListener('click', () => {
          setActiveSession(index);
          centerCard(index, true);
        });
        card.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            setActiveSession(index);
            centerCard(index, true);
          }
        });
      });

      sessionDots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const index = Number(dot.dataset.index);
          if (Number.isNaN(index)) return;
          setActiveSession(index);
          centerCard(index, true);
        });
      });

      sessionSlider.addEventListener('scroll', () => {
        if (isProgrammaticScroll || isInitialSelectionLock) return;

        let closestIndex = activeSessionIndex;
        let closestDistance = Infinity;
        sessionCards.forEach((card, index) => {
          const cardCenter = card.offsetLeft + card.clientWidth / 2;
          const sliderCenter = sessionSlider.scrollLeft + sessionSlider.clientWidth / 2;
          const distance = Math.abs(cardCenter - sliderCenter);
          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });
        if (closestIndex !== activeSessionIndex) {
          setActiveSession(closestIndex);
        }
      }, { passive: true });

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          const nextIndex = Math.max(activeSessionIndex - 1, 0);
          setActiveSession(nextIndex);
          centerCard(nextIndex, true);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          const nextIndex = Math.min(activeSessionIndex + 1, sessionCards.length - 1);
          setActiveSession(nextIndex);
          centerCard(nextIndex, true);
        });
      }

      setActiveSession(defaultSessionIndex);
      requestAnimationFrame(() => centerCard(defaultSessionIndex, false));

      // Recenter after fonts/images/layout settle to keep desktop aligned.
      setTimeout(() => {
        centerCard(defaultSessionIndex, false);
        setActiveSession(defaultSessionIndex);
      }, 140);
      setTimeout(() => {
        centerCard(defaultSessionIndex, false);
        setActiveSession(defaultSessionIndex);
      }, 420);

      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(() => {
          centerCard(defaultSessionIndex, false);
          setActiveSession(defaultSessionIndex);
        });
      }

      window.addEventListener('load', () => {
        centerCard(defaultSessionIndex, false);
        setActiveSession(defaultSessionIndex);
      });

      setTimeout(() => {
        isInitialSelectionLock = false;
        setActiveSession(defaultSessionIndex);
      }, 700);

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => centerCard(activeSessionIndex, false), 120);
      });
    }

    bindSessionEvents();
  </script>
</Layout>