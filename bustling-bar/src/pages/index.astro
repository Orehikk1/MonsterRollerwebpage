---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Monster Roller Budapest – Ride the Beast!">
  <!-- Hero -->
  <section class="relative h-[85vh] sm:h-[70vh] md:h-screen w-full overflow-hidden dark:bg-zinc-900">
    <img id="heroCarouselLayerA" src="/images/hero-night.jpg" alt="Monster Roller" class="absolute inset-0 w-full h-full object-cover brightness-75 dark:brightness-50 opacity-100 transition-opacity duration-700" />
    <img id="heroCarouselLayerB" src="/images/Nightpulse.jpg" alt="Monster Roller" class="absolute inset-0 w-full h-full object-cover brightness-75 dark:brightness-50 opacity-0 transition-opacity duration-700" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/30 dark:from-black/20 dark:via-transparent dark:to-[#fdf4e9]/30 flex flex-col items-center justify-center px-4 sm:px-6 text-center">
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-9xl font-black text-black dark:text-orange-600 mb-4 md:mb-8 tracking-tight drop-shadow-2xl animate-fadeInUp">
        RIDE THE MONSTER
      </h1>
      <p class="text-base sm:text-2xl md:text-3xl lg:text-4xl mb-6 md:mb-10 max-w-3xl lg:max-w-4xl font-light text-white drop-shadow-lg animate-fadeInUp delay-100">
        The most powerful and fun way to conquer Budapest - on an electric Monster Roller!
      </p>
      <a href="https://wa.me/36302584709?text=I%20want%20to%20book%20a%20Monster%20Roller%20now!" class="bg-orange-500 hover:bg-orange-400 text-black font-bold text-lg sm:text-xl md:text-2xl lg:text-3xl px-8 sm:px-12 md:px-16 py-4 md:py-6 lg:py-8 rounded-full shadow-2xl transform hover:scale-105 transition-all duration-300 animate-fadeInUp delay-200 animate-glow">
        Book via WhatsApp →
      </a>
    </div>
  </section>

  <!-- Wave transition -->
  <div class="relative h-3 sm:h-4 md:h-5 overflow-hidden" style="background: linear-gradient(to bottom, #fed7aa, #fef3c7);">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-orange-700/80 to-transparent animate-wave-fast"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-orange-600/70 to-transparent animate-wave delay-500"></div>
  </div>

  <!-- Rent Prices -->
  <section class="rp-section">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="rp-heading animate-on-scroll">Rent Prices</h2>
      <div class="rp-underline"></div>

      <div class="rp-grid">
        <!-- Single seat card -->
        <div class="rp-card animate-on-scroll" style="animation-delay:0s">
          <div class="rp-top-line rp-top-line--single"></div>
          <div class="rp-deco-num" aria-hidden="true">01</div>
          <div class="rp-card-inner">
            <div class="rp-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="7" r="4"/>
                <path d="M5.5 21a7 7 0 0 1 13 0"/>
              </svg>
            </div>
            <h3 class="rp-card-title">Single seat</h3>
            <div class="rp-price-row">
              <span class="rp-price">25 €</span>
              <span class="rp-badge">first hour</span>
            </div>
            <p class="rp-extra">+ 10 € each additional hour</p>
            <hr class="rp-divider" />
            <p class="rp-disclaimer">Max 15 people per roller (rental only, guide not included)</p>
            <a href="#book-your-ride" class="rp-btn">Book Now →</a>
          </div>
        </div>

        <!-- Double seat card -->
        <div class="rp-card animate-on-scroll" style="animation-delay:0.15s">
          <div class="rp-top-line rp-top-line--double"></div>
          <div class="rp-deco-num" aria-hidden="true">02</div>
          <div class="rp-card-inner">
            <div class="rp-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="7" r="3.5"/>
                <circle cx="16" cy="8" r="3"/>
                <path d="M2 21a7 7 0 0 1 14 0"/>
                <path d="M16 14c2.5 0 5 1.5 5.5 5"/>
              </svg>
            </div>
            <h3 class="rp-card-title">Double seat</h3>
            <div class="rp-price-row">
              <span class="rp-price">35 €</span>
              <span class="rp-badge">first hour</span>
            </div>
            <p class="rp-extra">+ 15 € each additional hour</p>
            <hr class="rp-divider" />
            <p class="rp-disclaimer">Max 15 people per roller (rental only, guide not included)</p>
            <a href="#book-your-ride" class="rp-btn">Book Now →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ── Rent Prices Section ── */
    .rp-section {
      padding: 100px 0;
      background:
        radial-gradient(ellipse at 50% 50%, rgba(249,115,22,0.06) 0%, transparent 70%),
        linear-gradient(to bottom, #1e1e1e 0%, #060606 50%, #141414 100%);
    }

    .rp-heading {
      font-size: clamp(2rem, 5vw, 3.75rem);
      font-weight: 900;
      color: #f97316;
      text-align: center;
      margin-bottom: 16px;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .rp-heading.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .rp-underline {
      width: 60px;
      height: 3px;
      background: #f97316;
      border-radius: 2px;
      margin: 0 auto 60px auto;
    }

    .rp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    /* Card shell */
    .rp-card {
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      background: #1a1a1a;
      border: 1px solid rgba(249,115,22,0.15);
      transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
      opacity: 0;
      transform: translateY(30px);
    }
    .rp-card.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .rp-card:hover {
      border-color: rgba(249,115,22,0.5);
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(249,115,22,0.1);
    }

    /* Decorative top gradient line */
    .rp-top-line {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      z-index: 1;
    }
    .rp-top-line--single {
      background: linear-gradient(to right, transparent, #f97316, transparent);
    }
    .rp-top-line--double {
      background: linear-gradient(to right, transparent, #ff8c00, transparent);
    }

    /* Large decorative background number */
    .rp-deco-num {
      position: absolute;
      bottom: -20px;
      right: 20px;
      font-size: 120px;
      font-weight: 900;
      color: rgba(249,115,22,0.04);
      pointer-events: none;
      z-index: 0;
      user-select: none;
      line-height: 1;
    }

    /* Card inner */
    .rp-card-inner {
      position: relative;
      z-index: 1;
      padding: 40px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* Icon */
    .rp-icon {
      margin-bottom: 16px;
    }

    /* Card title */
    .rp-card-title {
      font-size: 24px;
      font-weight: 700;
      color: #f97316;
      margin-bottom: 20px;
    }

    /* Price row */
    .rp-price-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }
    .rp-price {
      font-size: 64px;
      font-weight: 900;
      color: #ffffff;
      line-height: 1;
    }
    .rp-badge {
      background: rgba(249,115,22,0.12);
      border: 1px solid rgba(249,115,22,0.25);
      color: #f97316;
      font-size: 12px;
      border-radius: 20px;
      padding: 4px 12px;
      align-self: flex-start;
      margin-top: 8px;
    }

    /* Additional hour line */
    .rp-extra {
      font-size: 15px;
      color: rgba(255,255,255,0.6);
      margin-bottom: 0;
    }

    /* Divider */
    .rp-divider {
      width: 100%;
      border: none;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin: 16px 0;
    }

    /* Disclaimer */
    .rp-disclaimer {
      font-size: 12px;
      color: rgba(255,255,255,0.35);
      margin-bottom: 24px;
    }

    /* Book Now button */
    .rp-btn {
      display: block;
      width: 100%;
      background: #f97316;
      color: #000000;
      font-weight: 700;
      font-size: 14px;
      border-radius: 50px;
      padding: 14px;
      text-align: center;
      text-decoration: none;
      transition: background 0.25s ease;
    }
    .rp-btn:hover {
      background: #e56e00;
    }

    /* animate-on-scroll base state handled by card/heading rules above */

    /* Mobile: stack cards */
    @media (max-width: 640px) {
      .rp-grid {
        grid-template-columns: 1fr;
        gap: 24px;
      }
      .rp-card-inner {
        padding: 28px;
      }
      .rp-price {
        font-size: 52px;
      }
    }

    /* Light mode overrides */
    :global(html.light) .rp-section {
      background:
        radial-gradient(ellipse at 50% 50%, rgba(249,115,22,0.07) 0%, transparent 70%),
        linear-gradient(to bottom, #fffcf5 0%, #fdf4e9 55%, #fffaf0 100%);
    }
    :global(html.light) .rp-card {
      background: #ffffff;
      border-color: rgba(249,115,22,0.25);
      box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    }
    :global(html.light) .rp-card:hover {
      border-color: rgba(249,115,22,0.55);
    }
    :global(html.light) .rp-price {
      color: #111111;
    }
    :global(html.light) .rp-extra {
      color: rgba(15,23,42,0.65);
    }
    :global(html.light) .rp-disclaimer {
      color: rgba(15,23,42,0.45);
    }
    :global(html.light) .rp-divider {
      border-top-color: rgba(15,23,42,0.08);
    }
    :global(html.light) .rp-deco-num {
      color: rgba(249,115,22,0.05);
    }
    :global(html.light) .rp-btn {
      background: #f97316;
      color: #000000;
    }
    :global(html.light) .rp-btn:hover {
      background: #e56e00;
    }
  </style>

  <!-- Booking + Important Info -->
  <section id="book-your-ride" class="py-10 sm:py-14 md:py-18 lg:py-22 bg-gradient-to-b from-[#fdf4e9] to-white dark:from-black dark:to-zinc-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-6 lg:gap-8 lg:gap-12">
        <!-- Form -->
        <div class="lg:col-span-2 bg-white/90 dark:bg-zinc-800/90 backdrop-blur-sm p-6 sm:p-8 md:p-10 lg:p-12 rounded-3xl border border-orange-300/40 dark:border-orange-600/30 shadow-xl dark:shadow-orange-950/20 animate-slideInLeft delay-100">
          <h3 class="text-xl sm:text-2xl md:text-3xl font-bold text-orange-600 dark:text-orange-400 mb-6 md:mb-8 text-center">
            Book Your Ride
          </h3>
          <form id="bookingForm" netlify name="monster-roller-booking" method="POST">
            <input type="hidden" name="form-name" value="monster-roller-booking">

            <!-- Rental Type + фото -->
            <div class="mb-8">
              <div class="flex justify-center mb-6">
                <img id="rollerImage" src="/images/single-seat.jpg" alt="Selected Roller Model" class="w-48 h-48 sm:w-64 sm:h-64 md:w-72 md:h-72 object-cover rounded-2xl shadow-2xl border-4 border-orange-500/60 transition-all duration-500 animate-float" />
              </div>
              <div class="grid grid-cols-2 gap-4">
                <button type="button" id="singleBtn" class="py-5 rounded-2xl border-2 border-orange-500 dark:border-orange-500 bg-orange-500/10 dark:bg-orange-600/20 text-black dark:text-white font-semibold active transition-colors transform hover:scale-105 duration-200 animate-scaleIn">Single seat</button>
                <button type="button" id="doubleBtn" class="py-5 rounded-2xl border-2 border-orange-400 dark:border-orange-600 hover:border-orange-500 dark:hover:border-orange-500 text-black dark:text-white font-semibold transition-colors transform hover:scale-105 duration-200 animate-scaleIn delay-100">Double seat</button>
              </div>
            </div>

            <!-- Full Name -->
            <div class="mb-6 md:mb-8">
              <label class="block text-base md:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">Full Name</label>
              <input type="text" id="fullName" name="fullName" required placeholder="John Doe" class="w-full p-3 md:p-4 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors" />
            </div>

            <!-- Email + WhatsApp Number -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-6 mb-6 md:mb-8">
              <div>
                <label class="block text-base md:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">Email</label>
                <input type="email" id="email" name="email" required placeholder="example@email.com" class="w-full p-3 md:p-4 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors" />
              </div>
              <div>
                <label class="block text-base md:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">WhatsApp Number</label>
                <input type="tel" id="phone" name="phone" required placeholder="+36301234567" class="w-full p-3 md:p-4 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors" />
              </div>
            </div>

            <!-- Date & Time -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-6 mb-6 md:mb-8">
              <div>
                <label class="block text-sm md:text-base lg:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">Date</label>
                <input type="date" id="date" name="date" required min="2026-02-21" class="w-full p-1.5 md:p-3 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-xs md:text-sm text-gray-900 dark:text-white focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors">
              </div>
              <div>
                <label class="block text-sm md:text-base lg:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">Time</label>
                <input type="time" id="time" name="time" required min="10:00" max="18:00" step="900" class="w-full p-1.5 md:p-3 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-xs md:text-sm text-gray-900 dark:text-white focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors">
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 text-center">
                  Booking available 10:00–18:00
                </p>
              </div>
            </div>

            <!-- Hours & Number of people -->
            <div class="grid grid-cols-2 gap-3 md:gap-6 mb-6 md:mb-8">
              <div>
                <label class="block text-sm md:text-base lg:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">How many hours?</label>
                <select id="hours" name="hours" required class="w-full p-2 md:p-4 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-xs md:text-base text-gray-900 dark:text-white focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors">
                  <option value="1">1 hour</option>
                  <option value="2" selected>2 hours</option>
                  <option value="3">3 hours</option>
                  <option value="4">4 hours</option>
                  <option value="5">5 hours</option>
                  <option value="6">6+ hours (contact us)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm md:text-base lg:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">People</label>
                <input type="number" id="people" name="people" min="1" max="15" value="1" required class="w-full p-2 md:p-4 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-gray-900 dark:text-white focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors text-center text-base md:text-lg">
                <p id="peopleNote" class="text-xs text-orange-500 dark:text-orange-400 mt-1 text-center"></p>
              </div>
            </div>

            <!-- Notes -->
            <div class="mb-6 md:mb-8">
              <label class="block text-base md:text-lg mb-2 md:mb-3 text-gray-700 dark:text-gray-300">Notes / Special Requests</label>
              <textarea id="notes" name="notes" rows="3" placeholder="Any special requests? (e.g., music, group size, meeting point)" class="w-full p-3 md:p-4 bg-white dark:bg-zinc-700 border border-gray-300 dark:border-zinc-600 rounded-2xl text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:border-orange-500 dark:focus:border-orange-500 focus:ring-orange-500 transition-colors resize-none"></textarea>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Optional — tell us what you need!</p>
            </div>

            <!-- Total Price -->
            <div class="bg-white/80 dark:bg-zinc-700/80 p-5 md:p-6 rounded-2xl mb-6 md:mb-8 text-center shadow-inner animate-scaleInSlow">
              <p class="text-sm text-gray-600 dark:text-gray-400">Estimated total (rental only, guide not included)</p>
              <p id="totalPrice" class="text-4xl md:text-5xl font-black text-orange-600 dark:text-orange-400">50 €</p>
            </div>

            <button type="submit" class="w-full bg-orange-500 hover:bg-orange-400 dark:bg-orange-600 dark:hover:bg-orange-500 text-black dark:text-white font-bold text-xl md:text-2xl py-5 md:py-6 rounded-full transition transform hover:scale-105 duration-300 animate-fadeInUp delay-300">
              Send Booking Request
            </button>
          </form>
        </div>

        <!-- Important Info -->
        <div class="lg:col-span-1 bg-white/90 dark:bg-zinc-800/90 backdrop-blur-sm p-6 md:p-8 lg:p-10 rounded-3xl border border-orange-300/40 dark:border-orange-600/30 shadow-xl dark:shadow-orange-950/20 animate-slideInRight delay-100">
          <h4 class="text-xl md:text-2xl lg:text-3xl font-black text-orange-600 dark:text-orange-400 mb-6 md:mb-8 text-center tracking-wide">
            Important Info
          </h4>
          <ul class="space-y-4 md:space-y-6 text-gray-800 dark:text-gray-300 text-base md:text-lg">
            <li class="flex items-start gap-3 md:gap-4 animate-fadeInUp delay-100">
              <span class="text-xl md:text-2xl flex-shrink-0">👥</span>
              <span>Max 15 people per roller (both Single & Double)</span>
            </li>
            <li class="flex items-start gap-3 md:gap-4 animate-fadeInUp delay-200">
              <span class="text-xl md:text-2xl flex-shrink-0">💶</span>
              <span>
                Prices are for rental only – 
                <span class="text-red-500 dark:text-red-400 font-bold animate-pulse-slow">guide not included</span>
              </span>
            </li>
            <li class="flex items-start gap-3 md:gap-4 animate-fadeInUp delay-300">
              <span class="text-xl md:text-2xl flex-shrink-0">📱</span>
              <span>For groups >15 people – contact us via WhatsApp/email</span>
            </li>
            <li class="flex items-start gap-3 md:gap-4 animate-fadeInUp delay-400">
              <span class="text-xl md:text-2xl flex-shrink-0">⛑️</span>
              <span>Helmets provided free of charge</span>
            </li>
            <li class="flex items-start gap-3 md:gap-4 animate-fadeInUp">
              <span class="text-xl md:text-2xl flex-shrink-0">⏰</span>
              <span>Minimum rental 1 hour</span>
            </li>
            <li class="flex items-start gap-3 md:gap-4 animate-fadeInUp">
              <span class="text-xl md:text-2xl flex-shrink-0">🔒</span>
              <span>Deposit may be required for larger groups</span>
            </li>
          </ul>
          <div class="mt-8 md:mt-10 pt-5 md:pt-6 border-t border-orange-300/30 dark:border-orange-600/20 text-center text-sm md:text-base text-gray-700 dark:text-gray-300">
            <p class="font-medium">
              We'll reply within 15–30 minutes.
            </p>
            <p class="mt-2">
              Or message us on WhatsApp right now! <span class="text-orange-500 dark:text-orange-400">👉</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Session Selector -->
  <section class="session-selector-section">
    <div class="session-shell">
      <h2 class="session-title">Pick the Perfect Ride Session</h2>
      <p class="session-subtitle">Flexible options for solo riders, couples, and adrenaline-loving groups.</p>

      <div class="session-slider-controls" aria-label="Session slider controls">
        <button class="session-arrow" id="sessionPrev" type="button" aria-label="Previous session">&#8592;</button>
        <button class="session-arrow" id="sessionNext" type="button" aria-label="Next session">&#8594;</button>
      </div>

      <div class="session-slider" id="sessionSlider" aria-label="Session options">
        <article class="session-card theme-teal" data-index="0" tabindex="0">
          <div class="session-card-overlay"></div>
          <div class="session-card-content">
            <div class="session-card-head">
              <div class="session-name-wrap">
                <h3 class="session-name">Citadella</h3>
              </div>
              <span class="session-price">€35</span>
            </div>
            <p class="session-duration" style="color: rgba(255, 255, 255, 0.92) !important;">60 minutes</p>
            <p class="session-description" style="color: rgba(255, 255, 255, 0.86) !important;">Liberty Bridge, Statue of Liberty &amp; Philosophers' Garden — a quick ride up to the Citadel.</p>
            <div class="session-tags">
              <span>Quick Ride</span>
              <span>10 Photospots</span>
            </div>
            <button type="button" class="session-reserve-btn">Reserve</button>
          </div>
        </article>

        <article class="session-card theme-blue" data-index="1" tabindex="0">
          <div class="session-card-overlay"></div>
          <div class="session-card-content">
            <div class="session-card-head">
              <div class="session-name-wrap">
                <h3 class="session-name">Fisherman's Bastion</h3>
              </div>
              <span class="session-price">€49</span>
            </div>
            <p class="session-duration" style="color: rgba(255, 255, 255, 0.92) !important;">90 minutes</p>
