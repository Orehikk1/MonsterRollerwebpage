---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us — Monster Roller Budapest">
  <section class="contact-page pt-36 pb-16 sm:pt-36 sm:pb-20 md:pt-40 md:pb-24 bg-[#f7f3eb] dark:bg-[#0d0d0d]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 sm:mb-12 md:mb-14">
        <h1 class="contact-hero-title font-black text-4xl sm:text-5xl md:text-6xl tracking-tight">Get In Touch</h1>
        <div class="w-16 h-1 bg-[#F97316] rounded-full mx-auto mt-4 mb-5"></div>
        <p class="text-gray-600 dark:text-zinc-400 text-base sm:text-lg max-w-2xl mx-auto">
          Questions, bookings, or just want to say hello — we're always here.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
        <div class="rounded-2xl border border-black/10 dark:border-white/10 bg-[#ffffff] dark:bg-[#141414] p-6 md:p-8 shadow-xl">
          <form
            action="https://formsubmit.co/bpsegway@gmail.com"
            method="POST"
            class="space-y-5"
          >
            <input type="hidden" name="_subject" value="Monster Roller Contact Form" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_next" value="https://monster-roller-site.vercel.app/contact" />
            <div>
              <label for="fullName" class="block text-sm font-medium !text-zinc-800 dark:!text-zinc-300 mb-2">Full Name</label>
              <input id="fullName" name="fullName" type="text" required class="w-full rounded-[10px] border border-black/12 dark:border-white/15 bg-[#f7f7f7] dark:bg-[#1a1a1a] text-zinc-900 dark:text-white px-4 py-3 outline-none focus:border-[#F97316]" />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium !text-zinc-800 dark:!text-zinc-300 mb-2">Email</label>
              <input id="email" name="email" type="email" required class="w-full rounded-[10px] border border-black/12 dark:border-white/15 bg-[#f7f7f7] dark:bg-[#1a1a1a] text-zinc-900 dark:text-white px-4 py-3 outline-none focus:border-[#F97316]" />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium !text-zinc-800 dark:!text-zinc-300 mb-2">Phone/WhatsApp (optional)</label>
              <input id="phone" name="phone" type="text" class="w-full rounded-[10px] border border-black/12 dark:border-white/15 bg-[#f7f7f7] dark:bg-[#1a1a1a] text-zinc-900 dark:text-white px-4 py-3 outline-none focus:border-[#F97316]" />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium !text-zinc-800 dark:!text-zinc-300 mb-2">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full rounded-[10px] border border-black/12 dark:border-white/15 bg-[#f7f7f7] dark:bg-[#1a1a1a] text-zinc-900 dark:text-white px-4 py-3 outline-none focus:border-[#F97316]"></textarea>
            </div>

            <button type="submit" class="w-full rounded-full bg-[#F97316] hover:bg-[#ea620c] text-black font-bold py-3.5 transition">
              Send Message
            </button>
          </form>
        </div>

        <div class="space-y-4">
          <div class="rounded-2xl border border-black/10 dark:border-white/10 bg-[#ffffff] dark:bg-[#141414] p-6 shadow-xl">
            <div class="flex items-start gap-3">
              <span class="text-[#F97316]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-5.5 8-13a8 8 0 10-16 0c0 7.5 8 13 8 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
              </span>
              <div>
                <h3 class="contact-info-title text-lg font-bold">Find Us</h3>
                <p class="text-zinc-700 dark:text-zinc-300 mt-1">Haris köz 2, 1052 Budapest</p>
                <p class="text-zinc-500 dark:text-zinc-400 text-sm mt-1">Meet us at the starting point.</p>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-black/10 dark:border-white/10 bg-[#ffffff] dark:bg-[#141414] p-6 shadow-xl">
            <div class="flex items-start gap-3">
              <span class="text-[#F97316]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.84 11.84 0 0012.07.02C5.53.02.2 5.34.2 11.88c0 2.1.55 4.15 1.6 5.95L0 24l6.35-1.67a11.84 11.84 0 005.72 1.46h.01c6.54 0 11.87-5.33 11.87-11.88 0-3.17-1.24-6.15-3.43-8.43zm-8.45 18.3h-.01a9.85 9.85 0 01-5.02-1.37l-.36-.22-3.77.99 1.01-3.67-.24-.38a9.87 9.87 0 01-1.51-5.25c0-5.45 4.44-9.89 9.9-9.89 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 012.9 6.99c0 5.46-4.44 9.9-9.89 9.9zm5.43-7.43c-.3-.15-1.76-.87-2.04-.96-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.15-.17.2-.35.22-.65.08-.3-.15-1.27-.47-2.41-1.51-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.67-1.6-.92-2.2-.24-.57-.49-.49-.67-.49h-.57c-.2 0-.53.07-.8.38-.27.3-1.03 1.01-1.03 2.47 0 1.45 1.05 2.85 1.2 3.05.15.2 2.07 3.16 5.02 4.43.7.3 1.24.49 1.67.62.7.22 1.34.19 1.85.12.56-.08 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/></svg>
              </span>
              <div>
                <h3 class="contact-info-title text-lg font-bold">WhatsApp Us</h3>
                <p class="text-zinc-700 dark:text-zinc-300 mt-1">+36 30 258 4709</p>
                <a class="text-[#F97316] text-sm font-medium mt-1 inline-block" href="https://wa.me/36302584709" target="_blank" rel="noopener noreferrer">Chat with us now →</a>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-black/10 dark:border-white/10 bg-[#ffffff] dark:bg-[#141414] p-6 shadow-xl">
            <div class="flex items-start gap-3">
              <span class="text-[#F97316]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
              </span>
              <div>
                <h3 class="contact-info-title text-lg font-bold">Email Us</h3>
                <p class="text-zinc-700 dark:text-zinc-300 mt-1">bpsegway@gmail.com</p>
                <a class="text-[#F97316] text-sm font-medium mt-1 inline-block" href="mailto:bpsegway@gmail.com">Send an email →</a>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-black/10 dark:border-white/10 bg-[#ffffff] dark:bg-[#141414] p-6 shadow-xl">
            <div class="flex items-start gap-3">
              <span class="text-[#F97316]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v6l4 2"/></svg>
              </span>
              <div>
                <h3 class="contact-info-title text-lg font-bold">Opening Hours</h3>
                <p class="text-zinc-700 dark:text-zinc-300 mt-1">Every day 10:00 — 18:00</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 md:mt-12">
        <div class="w-full h-[400px] rounded-2xl overflow-hidden border border-black/12 dark:border-white/10">
          <iframe
            title="Monster Roller location"
            src="https://www.google.com/maps?q=Haris%20k%C3%B6z%202%2C%201052%20Budapest&output=embed"
            class="contact-google-map w-full h-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <style>
    html.light .contact-page {
      background: #f7f3eb !important;
    }

    html.light .contact-page .rounded-2xl {
      background: #ffffff !important;
      border-color: rgba(17, 24, 39, 0.18) !important;
    }

    html.dark .contact-page {
      background: #0d0d0d !important;
    }

    html.light .contact-page h1,
    html.light .contact-page h2,
    html.light .contact-page h3,
    html.light .contact-page label {
      color: #1f2937 !important;
    }

    html.dark:not(.light) .contact-page .contact-hero-title,
    html.dark:not(.light) .contact-page .contact-info-title {
      color: #ffffff !important;
    }

    html.light .contact-page .contact-hero-title,
    html.light .contact-page .contact-info-title {
      color: #111827 !important;
    }

    html.light .contact-page p,
    html.light .contact-page li,
    html.light .contact-page a {
      color: #374151;
    }

    html.light .contact-page a[href^="https://wa.me"],
    html.light .contact-page a[href^="mailto:"] {
      color: #f97316 !important;
    }

    .contact-google-map {
      transition: filter 220ms ease;
    }

    html.dark .contact-google-map {
      /* Visual dark-mode treatment for Google Maps iframe embed */
      filter: invert(92%) hue-rotate(180deg) saturate(0.85) contrast(0.95) brightness(0.9);
    }

  </style>
</Layout>
